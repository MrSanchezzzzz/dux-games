---
import BaseLayout from './BaseLayout.astro';
import '../styles/post.css';

interface Props {
  title: string;
  description: string;
  canonical: string;
  ogImage?: string;
  publishedTime?: string;
  tags?: string[];
  category?: string;
  date?: string;
  jsonLd?: string;
}

const { title, description, canonical, ogImage, publishedTime, tags = [], category, date, jsonLd } = Astro.props;
---
<BaseLayout {title} {description} {canonical} {ogImage} type="article" {jsonLd}>
  <section class="post-hero">
    <div class="container">
      <slot name="hero" />
    </div>
  </section>

  <section class="post-body">
    <div class="container">
      <article class="prose">
        <slot />
      </article>
    </div>
  </section>

  <div class="post-footer-nav">
    <div class="container">
      <slot name="footer-nav" />
    </div>
  </div>
</BaseLayout>
