---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');

const title = 'Support — DUX Games';
const description = 'Need help with a DUX Games app? Find answers to common questions or reach us directly by email.';
const canonical = 'https://mrsanchezzzzz.github.io/dux-games/support/';
---

<BaseLayout {title} {description} {canonical} lite>
  <!-- Hero -->
  <section class="hero">
    <div class="container hero-inner">
      <h1>We're here<br/>to <em>help.</em></h1>
      <p class="lede">Got a question, bug report, or just want to share feedback? We read every message and usually respond within 24 hours.</p>
      <div class="hero-cta">
        <a href="mailto:kremenchuksh@gmail.com" class="btn btn-primary">
          Email us
          <svg class="arrow" width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M3 13L13 3M13 3H6M13 3V10" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- FAQ topics -->
  <section class="sp-topics">
    <div class="container">
      <div class="section-head divider" style="justify-content: center;">
        <h2>Common topics</h2>
      </div>
      <div class="sp-grid">

        <div class="sp-card">
          <div class="sp-icon">
            <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
              <circle cx="11" cy="11" r="9" stroke="currentColor" stroke-width="1.6"/>
              <path d="M11 7v5l3 3" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <h3>Technical issues</h3>
          <p>App crashing, freezing, or behaving unexpectedly? Tell us your device model and iOS version and we'll look into it right away.</p>
        </div>

        <div class="sp-card">
          <div class="sp-icon">
            <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
              <path d="M11 2L13.5 8H20L14.5 12L16.5 18L11 14.5L5.5 18L7.5 12L2 8H8.5L11 2Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
            </svg>
          </div>
          <h3>Feature requests</h3>
          <p>Have an idea that would make our games better? We genuinely love hearing from players — send it over.</p>
        </div>


        <div class="sp-card">
          <div class="sp-icon">
            <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
              <path d="M11 1v4M11 17v4M4.22 4.22l2.83 2.83M14.95 14.95l2.83 2.83M1 11h4M17 11h4M4.22 17.78l2.83-2.83M14.95 7.05l2.83-2.83" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
            </svg>
          </div>
          <h3>General questions</h3>
          <p>Anything else on your mind — game design, company info, press or partnership inquiries. We're happy to chat.</p>
        </div>

        <div class="sp-card sp-card--cta">
          <p class="sp-cta-label mono">Ready to reach out?</p>
          <a href="mailto:kremenchuksh@gmail.com" class="sp-email">kremenchuksh@gmail.com</a>
          <p class="sp-cta-note">We reply within 24 hours, usually much sooner.</p>
        </div>

      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ---- Topics grid ---- */
  .sp-topics { padding-bottom: 80px; border-bottom: 1px solid var(--line); }

  .sp-grid {
    display: grid;
    max-width: 860px;
    margin-left: auto;
    margin-right: auto;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: var(--line);
    border: 1px solid var(--line);
    border-radius: 4px;
    overflow: hidden;
    margin-bottom: 0;
  }

  .sp-card {
    background: var(--bg);
    padding: 40px 36px 44px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    transition: background .2s ease;
  }
  .sp-card:hover { background: var(--bg-2); }

  .sp-icon {
    width: 44px;
    height: 44px;
    border: 1px solid var(--line-2);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--green);
    flex-shrink: 0;
  }

  .sp-card h3 {
    font-family: var(--serif);
    font-weight: 700;
    font-size: 20px;
    letter-spacing: -0.01em;
    margin: 0;
  }

  .sp-card p {
    font-size: 15px;
    line-height: 1.6;
    color: var(--muted);
    margin: 0;
  }

  /* CTA card */
  .sp-card--cta {
    background: var(--bg-2);
    justify-content: center;
    gap: 10px;
    border-left: none;
  }
  .sp-card--cta:hover { background: var(--bg-3); }

  .sp-cta-label {
    font-size: 11px;
    letter-spacing: 0.16em;
    color: var(--muted-2);
    text-transform: uppercase;
    margin: 0;
  }

  .sp-email {
    font-family: var(--serif);
    font-weight: 700;
    font-size: clamp(16px, 1.6vw, 22px);
    color: var(--green);
    letter-spacing: -0.01em;
    border-bottom: 1.5px solid transparent;
    transition: border-color .2s ease;
    word-break: break-all;
  }
  .sp-email:hover { border-color: var(--green); }

  .sp-cta-note {
    font-size: 13px;
    color: var(--muted-2);
    margin: 0;
  }

  /* ---- Responsive ---- */
  @media (max-width: 980px) {
    .sp-grid { grid-template-columns: 1fr; }
    .sp-card--cta { grid-column: auto; }
  }

  @media (max-width: 600px) {
    .sp-grid { grid-template-columns: 1fr; }
    .sp-card { padding: 30px 24px 34px; }
    .sp-card--cta { grid-column: auto; }
    .sp-topics { padding-bottom: 60px; }
  }
</style>
