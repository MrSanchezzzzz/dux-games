<style>
  .chart-fig svg { width: 92%; display: block; margin: 20px 0 8px; }
  .chart-fig .grid { stroke: rgba(255, 255, 255, 0.07); }
  .chart-fig .axis { stroke: var(--line-2); }
  .chart-fig .tick, .chart-fig .end-val, .chart-fig .readout { font: 12px var(--mono); fill: var(--muted); }
  .chart-fig .axis-label { font: 13px var(--sans); fill: var(--muted); transition: opacity 0.15s; }
  .chart-fig .end-name, .chart-fig .legend text { font: 13px var(--sans); fill: var(--ink); }
  .chart-fig .line-curve { stroke: var(--green); stroke-width: 2; fill: none; }
  .chart-fig .line-exp { stroke: #c98500; stroke-width: 2; fill: none; stroke-dasharray: 6 4; }
  .chart-fig .dot-curve { fill: var(--green); stroke: var(--bg-2); stroke-width: 2; }
  .chart-fig .dot-exp { fill: #c98500; stroke: var(--bg-2); stroke-width: 2; }
  .chart-fig .cross-line { stroke: rgba(255, 255, 255, 0.25); stroke-dasharray: 3 3; }
  .chart-fig .readout { fill: var(--ink); }
</style>

<script>
  const L12 = Math.log10(1.12), L5 = Math.log10(1.0005);
  const lg45 = Math.log10(45);
  const xpAt = (l: number) => 60 * l * l * 1.0001 ** (l * l);
  const mult = (v: number) => '×' + (v >= 100 ? Math.round(v).toLocaleString('en-US') : v.toFixed(1));
  const charts: Record<string, (fx: number) => { fx: number; ys: number[]; text: string }> = {
    'price-curve': (fx) => {
      const n = Math.round(fx * 50);
      const c = n * L12 + n * n * L5, e = n * L12;
      return { fx: n / 50, ys: [c / 3.2, e / 3.2], text: `level ${n} — ${mult(10 ** c)} vs ${mult(10 ** e)} pure` };
    },
    'shop-curve': (fx) => {
      const t = Math.round(fx * 40) / 10, income = 10 ** t, fixed = 45 / income;
      const clicks = fixed >= 1 ? String(+fixed.toFixed(1)) : fixed.toFixed(fixed >= 0.01 ? 2 : 4);
      const money = income >= 1000 ? '$' + +(income / 1000).toFixed(1) + 'K' : '$' + +income.toFixed(1);
      return { fx: t / 4, ys: [(lg45 + 3) / 5, (lg45 - t + 3) / 5], text: `at ${money} per click — 45 vs ${clicks} clicks` };
    },
    'xp-curve': (fx) => {
      const l = 1 + Math.round(fx * 19);
      const exp = 60 * ((xpAt(20) / 60) ** (1 / 19)) ** (l - 1);
      return { fx: (l - 1) / 19, ys: [xpAt(l) / 25000, exp / 25000], text: `level ${l} — ${Math.round(xpAt(l)).toLocaleString('en-US')} vs ${Math.round(exp).toLocaleString('en-US')} XP` };
    },
  };
  for (const [id, at] of Object.entries(charts)) {
    const fig = document.getElementById(id);
    const svg = fig?.querySelector('svg');
    const cross = fig?.querySelector<SVGGElement>('.cross');
    const readout = fig?.querySelector('.readout');
    const axisLabel = fig?.querySelector<SVGTextElement>('.axis-label');
    if (!svg || !cross || !readout) continue;
    const [line, ...dots] = Array.from(cross.children);
    svg.addEventListener('pointermove', (e) => {
      const r = svg.getBoundingClientRect();
      const p = at(Math.max(0, Math.min(1, (((e.clientX - r.left) / r.width) * 720 - 52) / 536)));
      const x = String(52 + p.fx * 536);
      line.setAttribute('x1', x); line.setAttribute('x2', x);
      p.ys.forEach((yf, i) => { dots[i].setAttribute('cx', x); dots[i].setAttribute('cy', String(360 - yf * 340)); });
      cross.style.opacity = '1';
      if (axisLabel) axisLabel.style.opacity = '0';
      readout.textContent = p.text;
    });
    svg.addEventListener('pointerleave', () => {
      cross.style.opacity = '0';
      if (axisLabel) axisLabel.style.opacity = '1';
      readout.textContent = '';
    });
  }
</script>
