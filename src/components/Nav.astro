---
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---
<header class="nav">
  <div class="container nav-inner">
    <a class="brand" href={`${base}`} aria-label="DUX Games — home">
      <img src={`${base}assets/dux-logo-horizontal-white.png`} alt="DUX Games" />
    </a>
    <button class="nav-toggle" id="navToggle" aria-label="Open menu" aria-expanded="false" aria-controls="navLinks">
      <span></span><span></span><span></span>
    </button>
    <nav class="nav-links" id="navLinks">
      <a class="link" href={`${base}#games`}>Games</a>
      <a class="link" href={`${base}#journal`}>Journal</a>
      <a class="link" href={`${base}#contact`}>Contact</a>
      <a class="btn btn-primary" href={`${base}wincode-98/`}>Play WinCode 98 <span class="arrow">↗</span></a>
    </nav>
  </div>
</header>
